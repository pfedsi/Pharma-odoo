<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════
         MÉDICAMENTS — product.template
    ════════════════════════════════════════════════════ -->

    <!-- Vue liste -->
    <record id="view_medicament_list" model="ir.ui.view">
        <field name="name">product.template.list.medicament</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <list string="Médicaments"
                  decoration-warning="alerte_stock == True">
                <field name="name" string="Nom"/>
                <field name="nom_generique" string="DCI" optional="show"/>
                <field name="dosage" string="Dosage" optional="show"/>
                <field name="forme_galenique_id" string="Forme" optional="show"/>
                <field name="fabricant" string="Fabricant" optional="hide"/>
                <field name="prix_achat_tnd" string="PA (TND)"
                       digits="[12,3]" optional="hide"/>
                <field name="prix_vente_tnd" string="PVP (TND)"
                       digits="[12,3]" optional="show"/>
                <field name="necessite_ordonnance" string="Ordo." optional="hide"/>
                <field name="quantite_stock" string="Stock"
                       digits="[12,0]" optional="show"/>
                <field name="alerte_stock" string="⚠" optional="show"
                       widget="boolean_favorite"/>
                <field name="active" optional="hide"/>
            </list>
        </field>
    </record>

    <!-- Vue kanban -->
    <record id="view_medicament_kanban" model="ir.ui.view">
        <field name="name">product.template.kanban.medicament</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <kanban quick_create="false">
                <field name="id"/>
                <field name="name"/>
                <field name="nom_generique"/>
                <field name="dosage"/>
                <field name="forme_galenique_id"/>
                <field name="prix_vente_tnd"/>
                <field name="alerte_stock"/>
                <field name="image_128"/>
                <templates>
                    <t t-name="kanban-card">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <t t-if="record.image_128.raw_value">
                                <img t-att-src="'/web/image/product.template/' + record.id.raw_value + '/image_128'"
                                     class="rounded"
                                     style="width:48px;height:48px;object-fit:cover;"
                                     alt="Médicament"/>
                            </t>
                            <t t-else="">
                                <div class="rounded bg-secondary d-flex align-items-center justify-content-center"
                                     style="width:48px;height:48px;">
                                    <i class="fa fa-pills text-white"/>
                                </div>
                            </t>
                            <strong class="o_kanban_record_title fs-6">
                                <field name="name"/>
                            </strong>
                        </div>
                        <div class="d-flex flex-wrap gap-1 mb-2">
                            <span t-if="record.nom_generique.raw_value"
                                  class="badge text-bg-secondary">
                                <t t-esc="record.nom_generique.value"/>
                            </span>
                            <span t-if="record.dosage.raw_value"
                                  class="badge text-bg-info">
                                <t t-esc="record.dosage.value"/>
                            </span>
                        </div>
                        <ul class="list-unstyled mb-1 small">
                            <li t-if="record.forme_galenique_id.raw_value">
                                <span class="text-muted">Forme :</span>
                                <t t-esc="record.forme_galenique_id.value"/>
                            </li>
                            <li>
                                <span class="text-muted">PVP :</span>
                                <strong><t t-esc="record.prix_vente_tnd.value"/></strong> TND
                            </li>
                        </ul>
                        <div t-if="record.alerte_stock.raw_value"
                             class="text-danger fw-bold small mt-1">
                            &#9888; Stock Faible
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Vue recherche -->
    <record id="view_medicament_search" model="ir.ui.view">
        <field name="name">product.template.search.medicament</field>
        <field name="model">product.template</field>
        <field name="arch" type="xml">
            <search string="Rechercher Médicaments">
                <field name="name"/>
                <field name="nom_commercial"/>
                <field name="nom_generique"/>
                <filter name="necessite_ordonnance"
                        string="Sur Ordonnance"
                        domain="[('necessite_ordonnance','=',True)]"/>
                <filter name="parapharmaceutique"
                        string="Parapharmaceutique"
                        domain="[('parapharmaceutique','=',True)]"/>
                <filter name="alerte_stock_actif"
                        string="Stock Faible"
                        domain="[('alerte_stock','=',True)]"/>
                <filter name="archives"
                        string="Archivés"
                        domain="[('active','=',False)]"/>
            </search>
        </field>
    </record>

    <!-- Héritage formulaire produit -->
    <record id="product_template_form_medicament" model="ir.ui.view">
        <field name="name">product.template.form.medicament</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view"/>
        <field name="arch" type="xml">

            <!-- Masquer champs non pertinents pour la pharmacie -->
            <xpath expr="//field[@name='categ_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='description_sale']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Masquer onglets natifs non utilisés -->
            <xpath expr="//page[@name='sales']" position="attributes">
                <attribute name="invisible">is_medicament</attribute>
            </xpath>
            <xpath expr="//page[@name='inventory']" position="attributes">
                <attribute name="invisible">is_medicament</attribute>
            </xpath>

            <!-- Toggle médicament avant le titre -->
            <xpath expr="//div[hasclass('oe_title')]" position="before">
                <div class="d-flex align-items-center mb-2">
                    <field name="is_medicament" widget="boolean_toggle"/>
                    <label for="is_medicament"
                           class="ms-2 fw-bold text-primary"
                           string="Médicament"/>
                </div>
            </xpath>

            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="placeholder">Nom du médicament</attribute>
            </xpath>

            <!-- Label prix dynamique -->
            <xpath expr="//label[@for='list_price']" position="replace">
                <label for="list_price"
                       string="Prix de Vente Public (TND)"
                       invisible="not is_medicament"/>
                <label for="list_price"
                       string="Prix de Vente"
                       invisible="is_medicament"/>
            </xpath>

            <!-- Champs cachés nécessaires au fonctionnement -->
            <xpath expr="//sheet" position="inside">
                <group invisible="1">
                    <field name="uom_id"/>
                    <field name="taxes_id"/>
                    <field name="supplier_taxes_id"/>
                    <field name="categ_id"/>
                </group>
            </xpath>

            <!-- Onglet Médicament -->
            <xpath expr="//page[@name='general_information']" position="after">
                <page string="Médicament" name="medicament_tab"
                      invisible="not is_medicament">

                    <group string="Identification">
                        <group>
                            <field name="nom_commercial" placeholder="ex : Doliprane"/>
                            <field name="nom_generique" placeholder="ex : Paracétamol"/>
                            <field name="code_barre_pharmacie" placeholder="CIP / EAN"/>
                            <field name="fabricant" placeholder="Laboratoire / Fabricant"/>
                        </group>
                        <group>
                            <field name="dosage" placeholder="ex : 500 mg"/>
                            <field name="forme_galenique_id"/>
                            <field name="necessite_ordonnance" widget="boolean_toggle"/>
                            <field name="parapharmaceutique" widget="boolean_toggle"/>
                            <field name="obligation_de_paiement" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <group string="Prix (TND)">
                        <group>
                            <field name="prix_achat_tnd"/>
                            <field name="prix_vente_tnd"/>
                            <field name="tva_taux"/>
                        </group>
                        <group>
                            <field name="seuil_alerte_stock"/>
                            <field name="quantite_stock" readonly="1"/>
                            <field name="alerte_stock" widget="boolean_toggle" readonly="1"/>
                            <field name="lot_count" readonly="1"/>
                        </group>
                    </group>

                    <!-- Bouton vers inventaire natif Odoo -->
                    <group string="Inventaire" invisible="not is_medicament">
                        <div class="o_field_widget">
                            <button name="action_open_quants"
                                    type="object"
                                    string="📦 Voir le Stock (Emplacements)"
                                    class="btn btn-secondary btn-sm"
                                    invisible="not is_medicament"/>
                           <button name="action_open_moves"
                                    type="object"
                                    string="🔄 Mouvements de Stock"
                                    class="btn btn-secondary btn-sm ms-2"
                                    invisible="not is_medicament"/>
                            <button name="action_open_inventory_lots"
                                    type="object"
                                    string="🧾 Voir l'Inventaire"
                                    class="btn btn-secondary btn-sm ms-2"
                                    invisible="not is_medicament"/>
                        </div>
                    </group>

                    <group string="Description / Indications">
                        <field name="description_pharmacie" nolabel="1"
                               placeholder="Indications thérapeutiques, contre-indications…"/>
                    </group>

                </page>
            </xpath>
        </field>
    </record>

    <!-- Action médicaments -->
    <record id="action_medicaments_pharmacie" model="ir.actions.act_window">
        <field name="name">Médicaments</field>
        <field name="res_model">product.template</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="domain">[('is_medicament','=',True)]</field>
        <field name="context">{
            'default_is_medicament': True,
            'default_type': 'consu',
            'default_is_storable': True
        }</field>
        <field name="search_view_id" ref="view_medicament_search"/>
        <field name="view_ids" eval="[(5,0,0),
            (0,0,{'view_mode':'list',   'view_id':ref('view_medicament_list')}),
            (0,0,{'view_mode':'kanban', 'view_id':ref('view_medicament_kanban')}),
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucun médicament enregistré.</p>
            <p>Créez votre premier médicament en cliquant sur <b>Nouveau</b>.</p>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════
         FORMES GALÉNIQUES
    ════════════════════════════════════════════════════ -->

    <record id="view_forme_galenique_list" model="ir.ui.view">
        <field name="name">pharmacie.forme.galenique.list</field>
        <field name="model">pharmacie.forme.galenique</field>
        <field name="arch" type="xml">
            <list string="Formes Galéniques" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_forme_galenique_form" model="ir.ui.view">
        <field name="name">pharmacie.forme.galenique.form</field>
        <field name="model">pharmacie.forme.galenique</field>
        <field name="arch" type="xml">
            <form string="Forme Galénique">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_forme_galenique" model="ir.actions.act_window">
        <field name="name">Formes Galéniques</field>
        <field name="res_model">pharmacie.forme.galenique</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>