<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════
         LISTE — Tickets
         ═══════════════════════════════════════════ -->
    <record id="view_pharmacy_ticket_list" model="ir.ui.view">
        <field name="name">pharmacy.ticket.list</field>
        <field name="model">pharmacy.ticket</field>
        <field name="arch" type="xml">
            <list string="Tickets"
                  decoration-success="etat == 'termine'"
                  decoration-warning="etat == 'appele'"
                  decoration-info="etat == 'en_attente'"
                  decoration-danger="etat == 'annule'"
                  decoration-muted="active == False">
                <field name="name"           string="N° Ticket"/>
                <field name="queue_id"       string="File"/>
                <field name="service_id"/>
                <field name="type_ticket"/>
                <field name="etat"
                       widget="badge"
                       decoration-success="etat == 'termine'"
                       decoration-warning="etat == 'appele'"
                       decoration-info="etat == 'en_attente'"
                       decoration-danger="etat == 'annule'"/>
                <field name="heure_creation" widget="datetime"/>
            </list>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         FORMULAIRE — Ticket
         ═══════════════════════════════════════════ -->
    <record id="view_pharmacy_ticket_form" model="ir.ui.view">
        <field name="name">pharmacy.ticket.form</field>
        <field name="model">pharmacy.ticket</field>
        <field name="arch" type="xml">
            <form string="Ticket">
                <header>
                    <button name="action_appeler"
                            string="Appeler"
                            type="object"
                            class="btn-primary"
                            invisible="etat != 'en_attente'"/>
                    <button name="action_terminer"
                            string="Terminer"
                            type="object"
                            class="btn-success"
                            invisible="etat != 'appele'"/>
                    <button name="action_annuler"
                            string="Annuler"
                            type="object"
                            class="btn-danger"
                            invisible="etat not in ['en_attente', 'appele']"/>
                    <field name="etat" widget="statusbar"
                           statusbar_visible="en_attente,appele,termine"/>
                </header>
                <sheet>

                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <div class="row g-3 mb-3">

                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-header bg-primary text-white py-2 px-3">
                                    <span class="fw-bold">
                                        <i class="fa fa-ticket me-2"/>Ticket
                                    </span>
                                </div>
                                <div class="card-body">
                                    <group>
                                        <field name="queue_id"/>
                                        <field name="service_id" readonly="1"/>
                                        <field name="type_ticket"/>
                                    </group>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="card border-0 shadow-sm h-100">
                                <div class="card-header bg-light py-2 px-3">
                                    <span class="fw-bold text-muted">
                                        <i class="fa fa-clock-o me-2"/>Horodatage
                                    </span>
                                </div>
                                <div class="card-body">
                                    <group>
                                        <field name="heure_creation" widget="datetime"/>
                                        <field name="heure_appel"    widget="datetime"/>
                                        <field name="heure_fin"      widget="datetime"/>
                                    </group>
                                </div>
                            </div>
                        </div>

                    </div>

                    <group string="Liens">
                        <field name="user_id"/>
                        <field name="reservation_id"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ═══════════════════════════════════════════
         ACTION
         ═══════════════════════════════════════════ -->
    <record id="action_pharmacy_ticket" model="ir.actions.act_window">
        <field name="name">Tickets</field>
        <field name="res_model">pharmacy.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Aucun ticket</p>
            <p>Les tickets sont créés automatiquement lors des réservations.</p>
        </field>
    </record>

</odoo>