<odoo>
    <record id="view_pharmacy_queue_history_list" model="ir.ui.view">
        <field name="name">pharmacy.queue.history.list</field>
        <field name="model">pharmacy.queue.history</field>
        <field name="arch" type="xml">
            <list>
                <field name="assistant_id"/>
                <field name="file_id"/>
                <field name="service_id"/>
                <field name="ticket_id"/>
                <field name="date_debut"/>
                <field name="date_fin"/>
                <field name="date_debut_traitement"/>
                <field name="date_fin_traitement"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacy_queue_history_form" model="ir.ui.view">
        <field name="name">pharmacy.queue.history.form</field>
        <field name="model">pharmacy.queue.history</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="assistant_id"/>
                        <field name="file_id"/>
                        <field name="service_id"/>
                        <field name="mode_rattachement"/>
                        <field name="poste_number"/>
                    </group>
                    <group>
                        <field name="date_debut"/>
                        <field name="date_fin"/>
                        <field name="ticket_id"/>
                        <field name="date_debut_traitement"/>
                        <field name="date_fin_traitement"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_pharmacy_queue_history" model="ir.actions.act_window">
    <field name="name">Historique des rattachements</field>
    <field name="res_model">pharmacy.queue.history</field>
    <field name="view_mode">list,form</field>
</record>
</odoo>