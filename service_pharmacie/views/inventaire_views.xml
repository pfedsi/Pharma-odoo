<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_stock_lot_pharmacie_list" model="ir.ui.view">
        <field name="name">stock.lot.pharmacie.list</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
             <list string="Inventaire Pharmacie"
                decoration-warning="state == 'faible'"
                decoration-muted="state == 'epuise'"
                decoration-success="state == 'disponible'">
                <field name="product_id"
                    string="Médicament"
                    widget="many2one_avatar_product"
                    optional="show"/>
                <field name="name" string="N° de Lot"/>

                <!-- ← AJOUT -->
                <field name="quantite_en_stock"
                    string="Qté en Stock"
                    optional="show"/>

                <field name="state"
                    string="État"
                    widget="badge"
                    decoration-success="state == 'disponible'"
                    decoration-warning="state == 'faible'"
                    decoration-danger="state == 'epuise'"/>
                <field name="note" string="Notes" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_stock_lot_pharmacie_form" model="ir.ui.view">
        <field name="name">stock.lot.pharmacie.form</field>
        <field name="model">stock.lot</field>
        <field name="arch" type="xml">
            <form string="Lot Médicament">
                <header>
                    <field name="state"
                           widget="statusbar"
                           statusbar_visible="disponible,faible,epuise"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name"
                                   placeholder="N° de lot..."
                                   readonly="id"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Produit">
                            <field name="product_id"
                                   domain="[('product_tmpl_id.is_medicament','=',True)]"
                                   options="{'no_create': True}"/>
                        </group>
                        <group string="Stock">
                            <field name="quantite_en_stock" readonly="1"/>
                            <field name="state" readonly="1"
                                   widget="badge"
                                   decoration-success="state == 'disponible'"
                                   decoration-warning="state == 'faible'"
                                   decoration-danger="state == 'epuise'"/>
                        </group>
                    </group>
                    <group string="Notes">
                        <field name="note"
                               nolabel="1"
                               placeholder="Informations complémentaires sur ce lot..."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
<record id="view_stock_lot_pharmacie_search" model="ir.ui.view">
    <field name="name">stock.lot.pharmacie.search</field>
    <field name="model">stock.lot</field>
    <field name="arch" type="xml">
        <search string="Rechercher dans l'inventaire">
            <field name="name"/>
            <field name="product_id"/>
        </search>
    </field>
</record>
   

    <record id="action_inventaire_pharmacie" model="ir.actions.act_window">
        <field name="name">Inventaire Pharmacie</field>
        <field name="res_model">stock.lot</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('product_id.product_tmpl_id.is_medicament','=',True)]</field>
        <field name="context">{'search_default_f_medicaments': 1}</field>
        <field name="search_view_id" ref="view_stock_lot_pharmacie_search"/>
        <field name="view_ids" eval="[(5,0,0),
            (0,0,{'view_mode':'list','view_id':ref('view_stock_lot_pharmacie_list')}),
            (0,0,{'view_mode':'form','view_id':ref('view_stock_lot_pharmacie_form')})
        ]"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucun lot médicament enregistré.
            </p>
            <p>Les lots sont créés automatiquement lors des réceptions de stock.</p>
        </field>
    </record>

</odoo>