<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_pharmacy_mobile_order_list" model="ir.ui.view">
        <field name="name">pharmacy.mobile.order.list</field>
        <field name="model">pharmacy.mobile.order</field>
        <field name="arch" type="xml">
            <list string="Commandes mobiles">
                <field name="name"/>
                <field name="state"/>
                <field name="partner_id"/>
                <field name="service_id"/>
                <field name="reservation_id"/>
                <field name="ticket_id"/>
                <field name="pos_order_id"/>
                <field name="item_count"/>
                <field name="amount_total"/>
            </list>
        </field>
    </record>

    <record id="view_pharmacy_mobile_order_form" model="ir.ui.view">
        <field name="name">pharmacy.mobile.order.form</field>
        <field name="model">pharmacy.mobile.order</field>
        <field name="arch" type="xml">
            <form string="Commande mobile">
                <sheet>
                    <group>
                        <group>
                            <field name="name" readonly="1"/>
                            <field name="state"/>
                            <field name="partner_id"/>
                            <field name="user_id" readonly="1"/>
                            <field name="session_token" readonly="1"/>
                        </group>
                        <group>
                            <field name="service_id" readonly="1"/>
                            <field name="reservation_id" readonly="1"/>
                            <field name="ticket_id" readonly="1"/>
                            <field name="pos_order_id" readonly="1"/>
                            <field name="prescription_id"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Lignes">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_tmpl_id"/>
                                    <field name="name"/>
                                    <field name="quantity"/>
                                    <field name="price_unit"/>
                                    <field name="subtotal" readonly="1"/>
                                    <field name="source_type"/>
                                    <field name="prescription_id"/>
                                    <field name="prescription_line_id"/>
                                    <field name="requires_prescription"/>
                                    <field name="product_type_label"/>
                                </list>
                            </field>
                        </page>

                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>

                    <group>
                        <field name="item_count" readonly="1"/>
                        <field name="amount_total" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pharmacy_mobile_order" model="ir.actions.act_window">
        <field name="name">Commandes mobiles</field>
        <field name="res_model">pharmacy.mobile.order</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>