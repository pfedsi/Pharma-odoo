<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_pharmacy_reservation_list" model="ir.ui.view">
            <field name="name">pharmacy.reservation.list</field>
            <field name="model">pharmacy.reservation</field>
            <field name="arch" type="xml">
                <list string="Réservations"
                      create="false"
                      delete="false"
                      decoration-success="statut == 'arrive'"
                      decoration-muted="statut == 'annule'"
                      decoration-info="statut == 'en_attente'">
                    <field name="display_name" string="Réservation"/>
                    <field name="user_id" string="Client"/>
                    <field name="service_id" string="Service"/>
                    <field name="localisation_id" string="Localisation"/>
                    <field name="date_heure_reservation" string="Créneau" widget="datetime"/>
                    <field name="statut" string="Statut"/>
                    <field name="ticket_id" string="Ticket"/>
                    <field name="queue_id" string="File d'attente"/>
                </list>
            </field>
        </record>

        <record id="view_pharmacy_reservation_form" model="ir.ui.view">
            <field name="name">pharmacy.reservation.form</field>
            <field name="model">pharmacy.reservation</field>
            <field name="arch" type="xml">
                <form string="Réservation" create="false" delete="false">
                    <sheet>
                        <div class="alert alert-success" role="alert"
                             invisible="statut != 'arrive'">
                            <i class="fa fa-check-circle me-1"/>
                            Réservation confirmée — ticket attribué :
                            <field name="ticket_id" readonly="1" nolabel="1"/>
                        </div>

                        <div class="alert alert-warning" role="alert"
                             invisible="statut != 'annule'">
                            <i class="fa fa-ban me-1"/>
                            Cette réservation a été annulée.
                        </div>

                        <group>
                            <group string="Réservation">
                                <field name="user_id" string="Client" readonly="1"/>
                                <field name="service_id" string="Service" readonly="1"/>
                                <field name="date_heure_reservation"
                                       string="Créneau réservé"
                                       widget="datetime"
                                       readonly="1"/>
                                <field name="statut"
                                       string="Statut"
                                       widget="statusbar"
                                       statusbar_visible="en_attente,arrive,annule"
                                       readonly="1"/>
                            </group>

                            <group string="File et ticket">
                                <field name="queue_id" string="File d'attente" readonly="1"/>
                                <field name="ticket_id" string="Ticket" readonly="1"/>
                            </group>
                        </group>

                        <separator string="Localisation"/>

                        <group>
                            <group string="Pharmacie">
                                <field name="localisation_id" string="Localisation" readonly="1"/>
                            </group>
                            <group string="Coordonnées GPS">
                                <field name="pharmacie_lat" string="Latitude" readonly="1"/>
                                <field name="pharmacie_lon" string="Longitude" readonly="1"/>
                                <field name="rayon_validation" string="Rayon GPS (m)" readonly="1"/>
                            </group>
                        </group>

                        <separator string="Notes"/>
                        <group>
                            <field name="notes" nolabel="1" readonly="1"/>
                        </group>
                    </sheet>

                    <div class="oe_chatter">
                        <field name="message_follower_ids"/>
                        <field name="message_ids"/>
                    </div>
                </form>
            </field>
        </record>

        <record id="view_pharmacy_reservation_search" model="ir.ui.view">
            <field name="name">pharmacy.reservation.search</field>
            <field name="model">pharmacy.reservation</field>
            <field name="arch" type="xml">
                <search>
                    <field name="user_id"/>
                    <field name="service_id"/>
                    <field name="localisation_id"/>

                    <filter name="filter_en_attente"
                            string="En attente"
                            domain="[('statut', '=', 'en_attente')]"/>

                    <filter name="filter_confirme"
                            string="Confirmées"
                            domain="[('statut', '=', 'arrive')]"/>

                    <filter name="filter_annule"
                            string="Annulées"
                            domain="[('statut', '=', 'annule')]"/>
                </search>
            </field>
        </record>

        <record id="action_pharmacy_reservation" model="ir.actions.act_window">
            <field name="name">Réservations</field>
            <field name="res_model">pharmacy.reservation</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="view_pharmacy_reservation_search"/>
            <field name="context">{'search_default_filter_en_attente': 1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aucune réservation pour le moment
                </p>
                <p>
                    Les réservations apparaissent ici dès que les clients
                    prennent un créneau via l'application.
                </p>
            </field>
        </record>

    </data>
</odoo>